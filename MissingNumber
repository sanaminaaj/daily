class Solution {
    public int missingNumber(int[] nums) {
       Arrays.sort(nums);
       //[0,1,3]
       int index=0;
       for(int i=0;i<nums.length;i++){
        if(nums[i]!=index){
            return i;
        }
        index=index+1;
       }
       return nums.length;
       
       
    }
}
